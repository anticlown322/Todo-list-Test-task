{
  "semi": true,
  "arrowParens": "avoid",
  "trailingComma": "all",
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "endOfLine": "auto",
  "bracketSameLine": true,
  "htmlWhitespaceSensitivity": "ignore",
  "vueIndentScriptAndStyle": true,
  "overrides": [
    {
      "files": ["*.component.html"],
      "options": {
        "parser": "angular",
        "htmlWhitespaceSensitivity": "strict"
      }
    },
    {
      "files": ["*.html"],
      "options": {
        "parser": "angular",
        "singleQuote": false
      }
    },
    {
      "files": ["*.scss", "*.css"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}

